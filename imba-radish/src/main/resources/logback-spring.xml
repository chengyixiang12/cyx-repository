<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ==================== 定义日志输出格式 ==================== -->
    <!-- 控制台格式：无年月日 -->
    <property name="CONSOLE_PATTERN" value="%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n"/>

    <!-- 文件格式：包含年月日 -->
    <property name="FILE_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %logger{36} [%thread] - %msg%n"/>

    <!-- 静默状态日志（生产环境推荐） -->
    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

    <!-- 禁用 JNDI（安全 + 启动速度） -->
    <disableJNDI>true</disableJNDI>

    <!-- 日志目录：优先使用 Spring 配置 -->
    <springProperty scope="context"
                    name="LOG_HOME"
                    source="log.file.home"
                    defaultValue="logs"/>

    <!-- ==================== 控制台：开发环境 ==================== -->
    <springProfile name="dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>
                    ${CONSOLE_PATTERN}
                </pattern>
            </encoder>
        </appender>
    </springProfile>

    <!-- ==================== 控制台：非开发环境 ==================== -->
    <springProfile name="!dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>
                    ${CONSOLE_PATTERN}
                </pattern>
            </encoder>
        </appender>
    </springProfile>

    <!-- ==================== 普通日志：INFO / WARN ==================== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/radish.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>
                ${LOG_HOME}/radish.%d{yyyy-MM-dd}.%i.log.gz
            </fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>20GB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>

        <encoder>
            <!-- 包含年月日，日志级别放在时分秒后面 -->
            <pattern>
                ${FILE_PATTERN}
            </pattern>
        </encoder>

        <!-- 接收 INFO 及以上 -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>

        <!-- 明确拒绝 ERROR（避免重复） -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>DENY</onMatch>
            <onMismatch>ACCEPT</onMismatch>
        </filter>
    </appender>

    <!-- ==================== 错误日志：仅 ERROR ==================== -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/error.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>
                ${LOG_HOME}/error.%d{yyyy-MM-dd}.%i.log.gz
            </fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>20GB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>

        <encoder>
            <pattern>
                ${FILE_PATTERN}
            </pattern>
        </encoder>

        <!-- 只接收 ERROR -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- MDC 感知的日志收集器 -->
    <appender name="MDC_COLLECTOR" class="com.soft.base.quartz.log.QuartzAppender">
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>${CONSOLE_PATTERN}</pattern>
        </layout>
    </appender>

    <!-- ==================== 根日志级别 ==================== -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
        <appender-ref ref="MDC_COLLECTOR"/>
    </root>

</configuration>