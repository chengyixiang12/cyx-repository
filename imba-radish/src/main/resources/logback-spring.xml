<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <statusListener class="ch.qos.logback.core.status.NopStatusListener" />
    <!--禁用JNDI-->
    <disableJNDI>true</disableJNDI>
    <withJansi>true</withJansi>
    <!--配置日志生成路径-->
    <springProperty scope="context" name="LOG_HOME" source="log.file.home" defaultValue="logs"/>
    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- 支持颜色的格式 -->
            <pattern>%highlight(%-5level) %cyan(%d{HH:mm:ss.SSS}) [%thread] %blue(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 文件输出：按天+大小滚动，自动压缩，保留30天 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/radish.log</file>
        <prudent>false</prudent>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/radish.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>20GB</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
            <rolloverOnStartup>true</rolloverOnStartup>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 日志级别 -->
    <root level="info">
        <appender-ref ref="CONSOLE" /> <!-- 控制台输出 -->
        <appender-ref ref="FILE" /> <!-- 文件输出 -->
    </root>
</configuration>
